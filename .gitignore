# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*
/config/master.key
/config/credentials/*.key

# Ignore default pids
/tmp/pids/*
!/tmp/pids/.keep

# Ignore all logfiles and tempfiles.
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
!/tmp/pids/

# Storage (Active Storage)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore assets builds
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore node_modules
/node_modules

# OS
.DS_Store
