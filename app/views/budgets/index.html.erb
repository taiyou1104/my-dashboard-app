<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-4xl mx-auto px-6 py-4 flex items-center gap-3">
      <%= link_to root_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>
      <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <h1 class="text-xl font-bold text-gray-900">家計簿</h1>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-6 py-8">

    <% if notice %>
      <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm">
        <%= notice %>
      </div>
    <% end %>

    <!-- 年月ナビゲーション -->
    <div class="flex items-center justify-between mb-8">
      <%= link_to budgets_path(year: @prev.year, month: @prev.month),
            class: "w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors" do %>
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>

      <div class="text-center">
        <h2 class="text-2xl font-bold text-gray-800"><%= @year %>年<%= @month %>月</h2>
      </div>

      <%= link_to budgets_path(year: @next.year, month: @next.month),
            class: "w-10 h-10 flex items-center justify-center bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors" do %>
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- 固定費カード -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-blue-500"></div>
            <h3 class="font-semibold text-gray-800">固定費</h3>
          </div>
          <%= link_to fixed_expenses_path, class: "text-xs text-blue-500 hover:text-blue-700 font-medium transition-colors" do %>
            設定 →
          <% end %>
        </div>

        <div class="px-6 py-4">
          <% if @fixed_expenses.empty? %>
            <p class="text-sm text-gray-400 text-center py-4">
              固定費が設定されていません<br>
              <%= link_to "設定する", fixed_expenses_path, class: "text-blue-500 hover:underline" %>
            </p>
          <% else %>
            <div class="space-y-2">
              <% @fixed_expenses.each do |expense| %>
                <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
                  <span class="text-sm text-gray-700"><%= expense.name %></span>
                  <span class="text-sm font-medium text-gray-800">¥<%= number_with_delimiter(expense.amount.to_i) %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <% unless @fixed_expenses.empty? %>
          <div class="px-6 py-3 bg-gray-50 rounded-b-2xl flex items-center justify-between">
            <span class="text-sm font-semibold text-gray-700">合計</span>
            <span class="text-base font-bold text-blue-600">¥<%= number_with_delimiter(@fixed_total.to_i) %></span>
          </div>
        <% end %>
      </div>

      <!-- 通信・光熱費カード -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-orange-400"></div>
          <h3 class="font-semibold text-gray-800">通信・光熱費</h3>
          <% unentered_count = MonthlyBudget::UTILITIES.count { |u| @budget.send(u[:key]).nil? } %>
          <% if unentered_count > 0 %>
            <span style="font-size:11px; background:#fef3c7; color:#b45309; padding:2px 8px; border-radius:99px; font-weight:600;">
              <%= unentered_count %>件未入力
            </span>
          <% end %>
        </div>

        <%= form_with model: @budget, url: budget_path(@budget), method: :patch do |f| %>
          <div class="px-6 py-4 space-y-3">
            <% MonthlyBudget::UTILITIES.each do |utility| %>
              <% value = @budget.send(utility[:key]) %>
              <% unentered = value.nil? %>
              <div style="<%= unentered ? 'background:#fffbeb; border:1px solid #fcd34d; border-radius:10px; padding:10px 12px;' : 'padding:2px 0;' %>"
                   class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-2 min-w-0">
                  <% if unentered %>
                    <span style="font-size:11px; color:#b45309; font-weight:600;">未入力</span>
                  <% end %>
                  <label class="text-sm text-gray-700 whitespace-nowrap"><%= utility[:label] %></label>
                </div>
                <div class="flex items-center gap-1">
                  <span class="text-sm text-gray-500">¥</span>
                  <%= f.number_field utility[:key],
                        value: value&.to_i,
                        min: 0,
                        placeholder: "0",
                        class: "w-28 text-right text-sm border border-gray-200 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-green-300" %>
                </div>
              </div>
            <% end %>
          </div>

          <div class="px-6 pb-5">
            <%= f.submit "保存する",
                  class: "w-full py-2.5 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-xl transition-colors cursor-pointer" %>
          </div>
        <% end %>

        <div class="px-6 py-3 bg-gray-50 rounded-b-2xl flex items-center justify-between">
          <span class="text-sm font-semibold text-gray-700">合計</span>
          <span class="text-base font-bold text-orange-500">¥<%= number_with_delimiter(@budget.utility_total.to_i) %></span>
        </div>
      </div>
    </div>

    <!-- 月合計カード -->
    <div class="mt-6 bg-white rounded-2xl border border-gray-200 shadow-sm px-6 py-5">
      <h3 class="font-semibold text-gray-800 mb-4">月合計</h3>
      <div class="space-y-2">
        <div class="flex items-center justify-between text-sm">
          <span class="text-gray-500">固定費</span>
          <span class="text-gray-700">¥<%= number_with_delimiter(@fixed_total.to_i) %></span>
        </div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-gray-500">通信・光熱費</span>
          <span class="text-gray-700">¥<%= number_with_delimiter(@budget.utility_total.to_i) %></span>
        </div>
      </div>
      <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between">
        <span class="font-bold text-gray-800">合計</span>
        <span class="text-xl font-bold text-green-600">¥<%= number_with_delimiter(@budget.grand_total(@fixed_total).to_i) %></span>
      </div>
    </div>

  </main>
</div>
