<div class="min-h-screen bg-gray-50" data-controller="loading roadmap-form">

  <!-- Loading overlay -->
  <div id="loading-overlay" class="hidden fixed inset-0 bg-white/80 backdrop-blur-sm z-50 flex items-center justify-center" data-loading-target="overlay">
    <div class="text-center">
      <div class="w-16 h-16 mx-auto mb-4 relative">
        <div class="absolute inset-0 rounded-full border-4 border-indigo-100"></div>
        <div class="absolute inset-0 rounded-full border-4 border-indigo-600 border-t-transparent animate-spin"></div>
      </div>
      <p class="text-gray-700 font-semibold text-lg">AIがロードマップを生成中...</p>
      <p class="text-gray-400 text-sm mt-1">しばらくお待ちください（30秒〜1分程度）</p>
    </div>
  </div>

  <header class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-3xl mx-auto px-6 py-4 flex items-center gap-4">
      <%= link_to roadmaps_path, class: "flex items-center gap-1 text-gray-400 hover:text-gray-700 transition-colors text-sm" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span>一覧に戻る</span>
      <% end %>
      <div class="text-gray-300">|</div>
      <h1 class="text-xl font-bold text-gray-900">新しいロードマップを作成</h1>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-10">
    <% if flash[:error] %>
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
        <%= flash[:error] %>
      </div>
    <% end %>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
      <div class="mb-6">
        <h2 class="text-lg font-semibold text-gray-800">学習計画を入力</h2>
        <p class="text-sm text-gray-500 mt-1">入力内容をもとにAIが一日ごとのタスクを自動生成します</p>
      </div>

      <%= form_with model: @roadmap, data: { action: "submit->loading#submit" } do |f| %>
        <div class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              勉強内容
              <span class="text-red-500">*</span>
            </label>
            <%= f.text_area :study_content,
                rows: 3,
                placeholder: "例：React と Next.js を使ったフロントエンド開発",
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none" %>
            <% if @roadmap.errors[:study_content].any? %>
              <p class="mt-1 text-xs text-red-500"><%= @roadmap.errors[:study_content].first %></p>
            <% end %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              詳細な目的
              <span class="text-red-500">*</span>
            </label>
            <%= f.text_area :purpose,
                rows: 4,
                placeholder: "例：フロントエンドエンジニアとして転職するため。ReactでSPAを作れるようになりたい。現在はHTML/CSSの基礎はわかる。",
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none" %>
            <% if @roadmap.errors[:purpose].any? %>
              <p class="mt-1 text-xs text-red-500"><%= @roadmap.errors[:purpose].first %></p>
            <% end %>
          </div>

          <%# 1日の勉強時間 %>
          <div data-roadmap-form-target="hoursGroup">
            <label class="block text-sm font-medium text-gray-700 mb-2">
              1日の勉強時間
              <span class="text-xs text-gray-400 font-normal ml-1">（入力すると期間をAIが自動決定）</span>
            </label>
            <div class="flex items-center gap-3">
              <%= f.number_field :daily_hours,
                  min: 0.5, max: 24, step: 0.5,
                  placeholder: "2",
                  data: { roadmap_form_target: "hoursField", action: "input->roadmap-form#hoursChanged" },
                  class: "w-32 px-4 py-3 border border-gray-300 rounded-xl text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
              <span class="text-sm text-gray-600">時間 / 日</span>
              <div class="flex gap-2 ml-2">
                <% [[0.5, "30分"], [1, "1時間"], [2, "2時間"], [3, "3時間"], [4, "4時間"]].each do |hours, label| %>
                  <button type="button"
                    onclick="document.getElementById('roadmap_daily_hours').value = '<%= hours %>'; this.closest('[data-controller]').querySelector('[data-action*=hoursChanged]').dispatchEvent(new Event('input'))"
                    class="px-3 py-1.5 text-xs bg-gray-100 hover:bg-indigo-100 hover:text-indigo-700 text-gray-600 rounded-lg transition-colors">
                    <%= label %>
                  </button>
                <% end %>
              </div>
            </div>
            <% if @roadmap.errors[:daily_hours].any? %>
              <p class="mt-1 text-xs text-red-500"><%= @roadmap.errors[:daily_hours].first %></p>
            <% end %>
          </div>

          <div class="flex items-center gap-3 text-xs text-gray-400">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span>または</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <%# 勉強期間 %>
          <div data-roadmap-form-target="durationGroup">
            <label class="block text-sm font-medium text-gray-700 mb-2">
              勉強期間（日数）
              <span class="text-xs text-gray-400 font-normal ml-1">（入力すると勉強時間は未設定になります）</span>
            </label>
            <div class="flex items-center gap-3">
              <%= f.number_field :duration_days,
                  min: 1, max: 365,
                  placeholder: "空欄でもOK（時間から自動決定）",
                  data: { roadmap_form_target: "durationField", action: "input->roadmap-form#durationChanged" },
                  class: "w-48 px-4 py-3 border border-gray-300 rounded-xl text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
              <span class="text-sm text-gray-600">日間</span>
              <div class="flex gap-2 ml-2">
                <% [[7, "1週間"], [14, "2週間"], [30, "1ヶ月"], [60, "2ヶ月"], [90, "3ヶ月"]].each do |days, label| %>
                  <button type="button"
                    data-action="click->roadmap-form#setDuration"
                    data-roadmap-form-days-param="<%= days %>"
                    class="px-3 py-1.5 text-xs bg-gray-100 hover:bg-indigo-100 hover:text-indigo-700 text-gray-600 rounded-lg transition-colors">
                    <%= label %>
                  </button>
                <% end %>
              </div>
            </div>
            <% if @roadmap.errors[:duration_days].any? %>
              <p class="mt-1 text-xs text-red-500"><%= @roadmap.errors[:duration_days].first %></p>
            <% end %>
            <% if @roadmap.errors[:base].any? %>
              <p class="mt-1 text-xs text-red-500"><%= @roadmap.errors[:base].first %></p>
            <% end %>
          </div>

          <div class="pt-2">
            <%= f.submit "ロードマップを生成する",
                data: { loading_target: "button" },
                class: "px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </main>
</div>
