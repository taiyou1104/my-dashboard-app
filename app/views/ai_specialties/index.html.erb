<div class="min-h-screen bg-gray-50">

  <!-- ヒーローヘッダー -->
  <div style="background:linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);">
    <div class="max-w-5xl mx-auto px-8 py-10">
      <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
        <%= link_to root_path, style: "color:rgba(255,255,255,0.7); display:flex; align-items:center; gap:6px; font-size:13px; text-decoration:none;" do %>
          <svg style="width:16px; height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          ダッシュボードへ
        <% end %>
      </div>
      <h1 style="font-size:28px; font-weight:800; color:white; margin-bottom:8px;">特化型AI</h1>
      <p style="font-size:15px; color:rgba(255,255,255,0.75); max-width:480px; line-height:1.6;">
        キーワードや概要を入力するだけで、各分野の専門AIが精度の高い回答を生成します
      </p>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      <% @specialties.each do |specialty| %>
        <%= link_to ai_specialty_path(specialty),
              style: "display:block; background:white; border-radius:20px; border:1.5px solid #e5e7eb; box-shadow:0 1px 4px rgba(0,0,0,0.06); text-decoration:none; overflow:hidden; transition:box-shadow 0.2s, transform 0.2s; position:relative;",
              onmouseover: "this.style.boxShadow='0 8px 24px rgba(0,0,0,0.12)'; this.style.transform='translateY(-2px)'",
              onmouseout:  "this.style.boxShadow='0 1px 4px rgba(0,0,0,0.06)'; this.style.transform='translateY(0)'" do %>

          <!-- カラーヘッダー -->
          <div style="background:<%= specialty.bg_color %>; padding:24px 24px 20px; display:flex; align-items:flex-start; justify-content:space-between;">
            <span style="font-size:36px; line-height:1;"><%= specialty.icon_emoji %></span>
            <div style="width:28px; height:28px; border-radius:50%; background:white; display:flex; align-items:center; justify-content:center; opacity:0.8;">
              <svg style="width:14px; height:14px; color:<%= specialty.color %>;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>

          <!-- コンテンツ -->
          <div style="padding:18px 20px 20px;">
            <h3 style="font-size:15px; font-weight:700; color:#1f2937; margin-bottom:6px;">
              <%= specialty.name %>
            </h3>
            <p style="font-size:12px; color:#6b7280; line-height:1.5;">
              <%= specialty.description %>
            </p>
          </div>

          <!-- カラーボトムライン -->
          <div style="height:3px; background:<%= specialty.color %>; margin:0 20px 20px; border-radius:99px;"></div>

        <% end %>
      <% end %>
    </div>
  </main>
</div>
