<div class="min-h-screen" style="background:#f8fafc; display:flex; flex-direction:column; height:100vh; overflow:hidden;"
     data-controller="ai-chat"
     data-ai-chat-url-value="<%= ai_specialty_ai_specialty_chats_path(@specialty) %>">

  <!-- ヘッダー -->
  <header style="background:white; border-bottom:1px solid #e5e7eb; flex-shrink:0;">
    <div class="max-w-3xl mx-auto px-6 py-4 flex items-center gap-4">
      <%= link_to ai_specialties_path, style: "color:#9ca3af; display:flex; align-items:center; text-decoration:none; padding:6px; border-radius:8px; transition:background 0.15s;",
            onmouseover: "this.style.background='#f3f4f6'",
            onmouseout:  "this.style.background='transparent'" do %>
        <svg style="width:20px; height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>
      <div style="width:42px; height:42px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0;"
           style="background:<%= @specialty.bg_color %>;">
        <div style="width:42px; height:42px; border-radius:14px; background:<%= @specialty.bg_color %>; display:flex; align-items:center; justify-content:center; font-size:22px;">
          <%= @specialty.icon_emoji %>
        </div>
      </div>
      <div style="flex:1; min-width:0;">
        <h1 style="font-size:17px; font-weight:700; color:#111827; margin:0;"><%= @specialty.name %>AI</h1>
        <p style="font-size:12px; color:#9ca3af; margin:0;"><%= @specialty.description %></p>
      </div>
    </div>
  </header>

  <!-- メッセージエリア -->
  <div style="flex:1; overflow-y:auto; padding:24px;" data-ai-chat-target="messages">

    <!-- 初期エンプティステート -->
    <div id="ai-chat-empty-state" style="height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:40px 20px;">
      <div style="width:72px; height:72px; border-radius:24px; background:<%= @specialty.bg_color %>; display:flex; align-items:center; justify-content:center; font-size:36px; margin-bottom:20px;">
        <%= @specialty.icon_emoji %>
      </div>
      <h2 style="font-size:20px; font-weight:700; color:#111827; margin-bottom:8px;"><%= @specialty.name %>AIへようこそ</h2>
      <p style="font-size:14px; color:#6b7280; margin-bottom:28px; max-width:360px; line-height:1.7;">
        キーワードや概要を入力するだけでOKです。<br>AIが自動で詳しい質問に変換して回答します。
      </p>
      <div style="background:white; border:1.5px solid #e5e7eb; border-radius:16px; padding:20px 24px; max-width:420px; width:100%; text-align:left;">
        <p style="font-size:11px; font-weight:700; color:<%= @specialty.color %>; margin-bottom:12px; letter-spacing:0.05em;">入力例</p>
        <% @specialty.input_placeholder.split("」「").each_with_index do |example, i| %>
          <% text = example.gsub(/^「|」$/, "") %>
          <div style="display:flex; align-items:center; gap:10px; padding:8px 0; <%= i > 0 ? 'border-top:1px solid #f3f4f6;' : '' %>">
            <span style="font-size:11px; background:<%= @specialty.bg_color %>; color:<%= @specialty.color %>; padding:2px 8px; border-radius:6px; font-weight:600; white-space:nowrap;">例</span>
            <span style="font-size:13px; color:#374151;"><%= text %></span>
          </div>
        <% end %>
      </div>
    </div>

  </div>

  <!-- ローディング（タイピングインジケーター） -->
  <div data-ai-chat-target="loading" style="display:none; padding:0 24px 8px;">
    <div class="max-w-3xl mx-auto" style="display:flex; align-items:center; gap:10px;">
      <div style="width:32px; height:32px; border-radius:10px; background:<%= @specialty.bg_color %>; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0;">
        <%= @specialty.icon_emoji %>
      </div>
      <div style="background:white; border:1px solid #e5e7eb; border-radius:4px 16px 16px 16px; padding:14px 18px; display:flex; gap:5px; align-items:center;">
        <span style="width:7px; height:7px; border-radius:50%; background:#9ca3af; animation:dot-bounce 1.2s infinite 0s;    display:inline-block;"></span>
        <span style="width:7px; height:7px; border-radius:50%; background:#9ca3af; animation:dot-bounce 1.2s infinite 0.2s;  display:inline-block;"></span>
        <span style="width:7px; height:7px; border-radius:50%; background:#9ca3af; animation:dot-bounce 1.2s infinite 0.4s;  display:inline-block;"></span>
      </div>
    </div>
  </div>

  <!-- 入力エリア -->
  <div style="flex-shrink:0; padding:12px 24px 20px; background:#f8fafc; border-top:1px solid #e5e7eb;">
    <div class="max-w-3xl mx-auto">
      <div style="background:white; border:1.5px solid #e5e7eb; border-radius:18px; padding:14px 16px; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
        <textarea data-ai-chat-target="input"
                  data-action="keydown->ai-chat#keydown input->ai-chat#autoResize"
                  placeholder="<%= @specialty.input_placeholder.split('」「').first.gsub(/^例：「|」$/, '') %>など..."
                  rows="2"
                  style="width:100%; resize:none; border:none; outline:none; font-size:14px; color:#111827; line-height:1.7; background:transparent;"></textarea>
        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:10px; padding-top:10px; border-top:1px solid #f3f4f6;">
          <span style="font-size:12px; color:#9ca3af;">Ctrl + Enter で送信</span>
          <button data-ai-chat-target="submit"
                  data-action="click->ai-chat#send"
                  style="padding:9px 22px; border-radius:12px; border:none; font-size:13px; font-weight:700; color:white; cursor:pointer; background:<%= @specialty.color %>; display:flex; align-items:center; gap:6px;">
            <svg style="width:14px; height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
            送信
          </button>
        </div>
      </div>
    </div>
  </div>

</div>

<style>
  @keyframes dot-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30%            { transform: translateY(-6px); opacity: 1; }
  }
</style>
