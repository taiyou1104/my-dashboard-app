<div class="min-h-screen bg-gray-50">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-2xl mx-auto px-6 py-4 flex items-center gap-3">
      <%= link_to budgets_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>
      <h1 class="text-xl font-bold text-gray-900">固定費設定</h1>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-6 py-8">

    <% if notice %>
      <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
        <%= alert %>
      </div>
    <% end %>

    <!-- 固定費一覧 -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm mb-6">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">登録済みの固定費</h2>
        <p class="text-xs text-gray-400 mt-0.5">毎月かかる費用を管理します</p>
      </div>

      <% if @fixed_expenses.empty? %>
        <div class="px-6 py-10 text-center text-gray-400 text-sm">
          固定費が登録されていません
        </div>
      <% else %>
        <div class="divide-y divide-gray-100">
          <% @fixed_expenses.each do |expense| %>
            <div class="px-6 py-3 flex items-center gap-3">
              <%= form_with model: expense, url: fixed_expense_path(expense), method: :patch, class: "flex items-center gap-3 flex-1" do |f| %>
                <%= f.text_field :name,
                      value: expense.name,
                      class: "flex-1 text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
                <div class="flex items-center gap-1">
                  <span class="text-sm text-gray-500">¥</span>
                  <%= f.number_field :amount,
                        value: expense.amount.to_i,
                        min: 1,
                        class: "w-28 text-right text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-300" %>
                </div>
                <%= f.submit "保存",
                      class: "text-sm px-4 py-2 bg-blue-50 hover:bg-blue-100 text-blue-600 font-medium rounded-lg transition-colors cursor-pointer" %>
              <% end %>
              <%= button_to fixed_expense_path(expense), method: :delete,
                    data: { turbo_confirm: "「#{expense.name}」を削除しますか？" },
                    class: "text-sm px-3 py-2 bg-red-50 hover:bg-red-100 text-red-500 font-medium rounded-lg transition-colors" do %>
                削除
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="px-6 py-3 bg-gray-50 rounded-b-2xl flex items-center justify-between">
          <span class="text-sm font-semibold text-gray-700">月合計</span>
          <span class="text-base font-bold text-blue-600">
            ¥<%= number_with_delimiter(@fixed_expenses.sum { |e| e.amount.to_i }) %>
          </span>
        </div>
      <% end %>
    </div>

    <!-- 新規追加フォーム -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-gray-800">固定費を追加</h2>
      </div>

      <%= form_with model: @new_expense, url: fixed_expenses_path, method: :post, class: "px-6 py-5" do |f| %>
        <div class="flex items-center gap-3">
          <%= f.text_field :name,
                placeholder: "例：家賃、Netflix など",
                class: "flex-1 text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-green-300" %>
          <div class="flex items-center gap-1">
            <span class="text-sm text-gray-500">¥</span>
            <%= f.number_field :amount,
                  placeholder: "0",
                  min: 1,
                  class: "w-28 text-right text-sm border border-gray-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-green-300" %>
          </div>
          <%= f.submit "追加",
                class: "text-sm px-5 py-2.5 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg transition-colors cursor-pointer" %>
        </div>
        <% if @new_expense.errors.any? %>
          <div class="mt-3 text-sm text-red-500">
            <% @new_expense.errors.full_messages.each do |msg| %>
              <p><%= msg %></p>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

  </main>
</div>
