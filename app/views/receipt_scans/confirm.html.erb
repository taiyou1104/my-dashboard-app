<div class="min-h-screen bg-gray-50">
  <header class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-2xl mx-auto px-10 py-6 flex items-center gap-4">
      <%= link_to budgets_path(year: @budget.year, month: @budget.month),
            class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>
      <div class="w-10 h-10 bg-violet-600 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
      </div>
      <div>
        <h1 class="text-xl font-bold text-gray-900">スキャン結果</h1>
        <p class="text-xs text-gray-400"><%= @budget.year %>年<%= @budget.month %>月</p>
      </div>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-8 py-10">

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <div style="padding:22px 32px;" class="border-b border-gray-100">
        <h2 class="font-semibold text-gray-800" style="font-size:16px;">読み取った項目</h2>
        <p class="text-sm text-gray-400 mt-1">追加する項目にチェックを入れて、名前・金額を確認してください</p>
      </div>

      <%= form_with url: batch_create_budget_monthly_expenses_path(@budget), method: :post do |f| %>
        <div style="padding:16px 32px 24px;" class="space-y-3">
          <% @items.each_with_index do |item, i| %>
            <div style="display:flex; align-items:center; gap:12px; padding:14px 16px; border:1.5px solid #e5e7eb; border-radius:14px;">
              <input type="checkbox"
                     name="items[<%= i %>][selected]"
                     value="1"
                     checked
                     style="width:18px; height:18px; accent-color:#7c3aed; flex-shrink:0; cursor:pointer;">
              <input type="text"
                     name="items[<%= i %>][name]"
                     value="<%= item['name'] %>"
                     style="flex:1; min-width:0; font-size:14px; border:1px solid #e5e7eb; border-radius:10px; padding:9px 12px; outline:none;">
              <span style="color:#9ca3af; font-size:14px; flex-shrink:0;">¥</span>
              <input type="number"
                     name="items[<%= i %>][amount]"
                     value="<%= item['amount'].to_i %>"
                     min="1"
                     style="width:90px; text-align:right; font-size:14px; border:1px solid #e5e7eb; border-radius:10px; padding:9px 10px; outline:none; flex-shrink:0;">
            </div>
          <% end %>
        </div>

        <div style="padding:0 32px 28px; display:flex; gap:12px;">
          <%= link_to "キャンセル",
                budgets_path(year: @budget.year, month: @budget.month),
                style: "flex:1; display:block; text-align:center; padding:14px; background:#f3f4f6; color:#6b7280; font-size:15px; font-weight:600; border-radius:14px; text-decoration:none;" %>
          <%= f.submit "選択した項目を追加する",
                style: "flex:2; padding:14px; background:#7c3aed; color:white; font-size:15px; font-weight:700; border-radius:14px; border:none; cursor:pointer;" %>
        </div>
      <% end %>
    </div>

  </main>
</div>
