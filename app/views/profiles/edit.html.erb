<div class="min-h-screen bg-gray-50">
  <header class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-3xl mx-auto px-6 py-4 flex items-center gap-3">
      <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </div>
      <h1 class="text-xl font-bold text-gray-900">プロフィール設定</h1>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-10">
    <% if notice %>
      <div class="mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm">
        <%= notice %>
      </div>
    <% end %>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
      <div class="mb-6">
        <h2 class="text-lg font-semibold text-gray-800">あなたの技術・資格情報</h2>
        <p class="text-sm text-gray-500 mt-1">AIがあなたのレベルに合ったロードマップを生成するために使用します</p>
      </div>

      <%= form_with model: @profile, url: profile_path, method: :patch do |f| %>
        <div class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              スキル・経験
              <span class="text-red-500">*</span>
            </label>
            <%= f.text_area :skills,
                rows: 5,
                placeholder: "例：\n・Ruby on Rails 3年（個人開発メイン）\n・Python 基礎（データ分析入門レベル）\n・HTML/CSS 実務経験あり",
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none" %>
            <% if @profile.errors[:skills].any? %>
              <p class="mt-1 text-xs text-red-500"><%= @profile.errors[:skills].first %></p>
            <% end %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              保有資格・実績
              <span class="text-gray-400 text-xs">（任意）</span>
            </label>
            <%= f.text_area :certifications,
                rows: 4,
                placeholder: "例：\n・基本情報技術者試験（2023年取得）\n・TOEIC 750点\n・AWS SAA取得予定",
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none" %>
          </div>

          <div class="flex gap-3 pt-2">
            <%= f.submit "保存する",
                class: "px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors cursor-pointer" %>
            <% if Profile.exists? %>
              <%= link_to "キャンセル", roadmaps_path, class: "px-6 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-xl transition-colors" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </main>
</div>
