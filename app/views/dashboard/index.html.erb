<div class="min-h-screen bg-gray-50">
  <header class="bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-5xl mx-auto px-8 py-5 flex items-center gap-3">
      <div class="w-9 h-9 bg-indigo-600 rounded-xl flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
        </svg>
      </div>
      <h1 class="text-xl font-bold text-gray-900">マイダッシュボード</h1>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-8 py-10">
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-gray-800">アプリ一覧</h2>
      <p class="text-sm text-gray-400 mt-1">利用したいアプリを選択してください</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- 特化型AI -->
      <%= link_to ai_specialties_path, class: "group block bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:border-violet-300 transition-all duration-200" do %>
        <div class="p-7">
          <div class="w-12 h-12 bg-violet-100 rounded-xl flex items-center justify-center mb-5 group-hover:bg-violet-200 transition-colors text-2xl">🤖</div>
          <h3 class="text-base font-semibold text-gray-800 group-hover:text-violet-700 transition-colors">特化型AI</h3>
          <p class="text-sm text-gray-400 mt-1.5">キーワードを入れるだけで精度の高い回答</p>
        </div>
        <div class="px-7 pb-5 flex items-center gap-1 text-sm font-medium text-violet-500 opacity-0 group-hover:opacity-100 transition-opacity">
          <span>開く</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      <% end %>

      <!-- ロードマップ -->
      <%= link_to roadmaps_path, class: "group block bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:border-indigo-300 transition-all duration-200" do %>
        <div class="p-7">
          <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center mb-5 group-hover:bg-indigo-200 transition-colors">
            <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-gray-800 group-hover:text-indigo-700 transition-colors">ロードマップ</h3>
          <p class="text-sm text-gray-400 mt-1.5">目標と計画を視覚的に管理</p>
        </div>
        <div class="px-7 pb-5 flex items-center gap-1 text-sm font-medium text-indigo-500 opacity-0 group-hover:opacity-100 transition-opacity">
          <span>開く</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      <% end %>

      <!-- 家計簿 -->
      <%= link_to budgets_path, class: "group block bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md hover:border-green-300 transition-all duration-200" do %>
        <div class="p-7">
          <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-5 group-hover:bg-green-200 transition-colors">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-gray-800 group-hover:text-green-700 transition-colors">家計簿</h3>
          <p class="text-sm text-gray-400 mt-1.5">月ごとの収支・固定費を管理</p>
        </div>
        <div class="px-7 pb-5 flex items-center gap-1 text-sm font-medium text-green-500 opacity-0 group-hover:opacity-100 transition-opacity">
          <span>開く</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
      <% end %>

    </div>
  </main>
</div>
