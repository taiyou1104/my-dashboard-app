<div id="task_<%= task.id %>" class="flex items-start gap-4 p-4 rounded-xl <%= task.completed ? 'bg-gray-50' : 'bg-white border border-gray-200' %> transition-all">
  <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center text-xs font-bold
    <%= task.completed ? 'bg-emerald-100 text-emerald-600' : 'bg-indigo-100 text-indigo-600' %>">
    Day<br><%= task.day_number %>
  </div>

  <div class="flex-1 min-w-0">
    <h4 class="text-sm font-semibold <%= task.completed ? 'line-through text-gray-400' : 'text-gray-800' %>">
      <%= task.title %>
    </h4>
    <p class="text-sm text-gray-500 mt-0.5 <%= task.completed ? 'line-through' : '' %>">
      <%= task.description %>
    </p>
  </div>

  <%= form_with url: task_path(task), method: :patch, class: "flex-shrink-0" do |f| %>
    <button type="submit"
      class="w-7 h-7 rounded-full border-2 flex items-center justify-center transition-all
        <%= task.completed ? 'bg-emerald-500 border-emerald-500 hover:bg-emerald-600' : 'border-gray-300 hover:border-indigo-400' %>">
      <% if task.completed %>
        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      <% end %>
    </button>
  <% end %>
</div>
